---
import "../styles/global.css";
import Header from "../components/HeaderWrapper.astro";
import Footer from "../components/FooterWrapper.astro";
import ImageModal from "../components/ImageModal";
import { getLangFromUrl, getAlternateUrl } from "../i18n/astro";

const {
    title,
    description = "Journey Inward, Explore Outward with Marga Adventure. Specialized in high-end trekking, spiritual retreats, and cultural tours in Nepal, Bhutan, and Tibet.",
    image = "/images/hero/hero-bg.webp",
    type = "website",
    headerVariant = "transparent",
    keywords = "trekking nepal, spiritual retreats, bhutan tours, tibet travel, marga adventure, luxury trekking, cultural tours, trekking népal, voyage spirituel, circuit bhoutan, voyage tibet, randonnée himalaya, agence voyage népal, guide francophone népal",
    robots = "index, follow",
    schema = null,
} = Astro.props;

// ── Language detection from URL ────────────────────────────────────────────────
const lang = getLangFromUrl(Astro.url);
const ogLocale = lang === 'fr' ? 'fr_FR' : 'en_US';
const ogLocaleAlt = lang === 'fr' ? 'en_US' : 'fr_FR';

// ── Alternate URLs for hreflang ────────────────────────────────────────────────
const site = Astro.site || "https://margaadventure.com";
const { enUrl, frUrl } = getAlternateUrl(Astro.url, site);
const canonicalURL = lang === 'fr' ? frUrl : enUrl;

const socialImageURL = new URL(image, Astro.url);

// ── Skip link label by locale ──────────────────────────────────────────────────
const skipLabel = lang === 'fr' ? 'Aller au contenu principal' : 'Skip to main content';
const whatsappLabel = lang === 'fr' ? 'Discutez avec nous sur WhatsApp' : 'Chat with us on WhatsApp';
const whatsappTooltip = lang === 'fr' ? 'Discutez avec nous' : 'Chat with us';

// Default JSON-LD
const organizationSchema = {
    "@context": "https://schema.org",
    "@type": "Organization",
    name: "Marga Adventure",
    url: "https://margaadventure.com",
    logo: "https://margaadventure.com/logo.webp",
    description:
        "Specialized in high-end trekking, spiritual retreats, and cultural tours in Nepal, Bhutan, and Tibet.",
    sameAs: [
        "https://www.facebook.com/margaadventure",
        "https://www.instagram.com/margaadventure",
    ],
    contactPoint: {
        "@type": "ContactPoint",
        telephone: "+9779700050945",
        contactType: "customer service",
        areaServed: ["NP", "BT", "CN-XZ", "FR", "BE", "CH"],
        availableLanguage: ["English", "French"],
    },
};
---

<!doctype html>
<html lang={lang} class="scroll-smooth">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/png" href="/favicon.png" />
        <link rel="icon" type="image/webp" href="/favicon.webp" />
        <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="generator" content={Astro.generator} />
        <link rel="sitemap" href="/sitemap-index.xml" />

        <!-- Primary Meta Tags -->
        <title>{title} | Marga Adventure</title>
        <meta name="title" content={`${title} | Marga Adventure`} />
        <meta name="description" content={description} />
        <meta name="keywords" content={keywords} />
        <meta name="robots" content={robots} />
        <link rel="canonical" href={canonicalURL} />

        <!-- hreflang — multilingual SEO -->
        <link rel="alternate" hreflang="en" href={enUrl} />
        <link rel="alternate" hreflang="fr" href={frUrl} />
        <link rel="alternate" hreflang="x-default" href={enUrl} />

        <!-- Open Graph / Facebook -->
        <meta property="og:type" content={type} />
        <meta property="og:url" content={canonicalURL} />
        <meta property="og:title" content={`${title} | Marga Adventure`} />
        <meta property="og:description" content={description} />
        <meta property="og:image" content={socialImageURL} />
        <meta property="og:site_name" content="Marga Adventure" />
        <meta property="og:locale" content={ogLocale} />
        <meta property="og:locale:alternate" content={ogLocaleAlt} />

        <!-- Twitter -->
        <meta property="twitter:card" content="summary_large_image" />
        <meta property="twitter:url" content={canonicalURL} />
        <meta property="twitter:title" content={`${title} | Marga Adventure`} />
        <meta property="twitter:description" content={description} />
        <meta property="twitter:image" content={socialImageURL} />
        <meta property="twitter:site" content="@margaadventure" />

        <!-- JSON-LD Schemas -->
        <script
            type="application/ld+json"
            set:html={JSON.stringify(organizationSchema)}
        />
        {
            schema && (
                <script
                    type="application/ld+json"
                    set:html={JSON.stringify(schema)}
                />
            )
        }
    </head><body class="bg-white text-gray-900 font-sans overflow-x-hidden">
        <a
            href="#main-content"
            class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 z-200 bg-brand text-white px-4 py-2 rounded-md"
        >
            {skipLabel}
        </a>
        <Header forceOpaque={headerVariant === "opaque"} initialLocale={lang} />
        <ImageModal client:only="react" />
        <main id="main-content">
            <slot />
        </main>
        <a
            href="https://wa.me/9779700050945"
            target="_blank"
            rel="noopener noreferrer"
            aria-label={whatsappLabel}
            class="fixed bottom-8 right-8 z-100 flex items-center justify-center w-16 h-16 bg-[#25D366] rounded-full shadow-2xl hover:scale-110 transition-transform duration-300 group"
        >
            <svg
                class="w-9 h-9 text-white"
                fill="currentColor"
                viewBox="0 0 24 24"
                xmlns="http://www.w3.org/2000/svg"
                aria-hidden="true"
            >
                <path
                    d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"
                ></path>
            </svg>
            <span
                class="absolute right-full mr-4 bg-white text-black px-3 py-1 rounded-lg text-xs font-bold whitespace-nowrap opacity-0 group-hover:opacity-100 transition-opacity shadow-lg"
                >{whatsappTooltip}</span
            >
        </a>
        <Footer initialLocale={lang} />

        <script>
            // ── Image Lightbox (event delegation) ──────────────────────────────
            document.addEventListener(
                "click",
                (e) => {
                    const target = e.target;
                    if (!target || !(target instanceof HTMLElement)) return;
                    const img = target instanceof HTMLImageElement ? target : null;
                    if (!img || img.closest("button, a") || img.hasAttribute("data-no-lightbox")) return;
                    e.preventDefault();
                    e.stopPropagation();
                    window.dispatchEvent(new CustomEvent("open-image-modal", { detail: img.src }));
                },
                { passive: false },
            );

            document.addEventListener("keydown", (e) => {
                const activeEl = document.activeElement;
                if ((e.key === "Enter" || e.key === " ") && activeEl instanceof HTMLImageElement) {
                    if (!activeEl.closest("button, a") && !activeEl.hasAttribute("data-no-lightbox")) {
                        e.preventDefault();
                        window.dispatchEvent(new CustomEvent("open-image-modal", { detail: activeEl.src }));
                    }
                }
            });

            // ── i18n: sync <html lang> + localStorage on locale change ─────────
            window.addEventListener("marga:language-changed", (e) => {
                const locale = (e as CustomEvent<string>).detail;
                if (!locale) return;
                document.documentElement.lang = locale;
                // Navigate to the locale-prefixed URL
                const path = window.location.pathname;

                if (locale === 'fr') {
                    if (!path.startsWith('/fr')) {
                        window.location.href = `/fr${path === '/' ? '' : path}`;
                    }
                } else {
                    if (path.startsWith('/fr')) {
                        const newPath = path.replace(/^\/fr/, '') || '/';
                        window.location.href = newPath;
                    }
                }
            });

            // ── Sync lang attribute from URL on page load ──────────────────────
            const urlLang = window.location.pathname.startsWith('/fr') ? 'fr' : 'en';
            document.documentElement.lang = urlLang;
            // Keep localStorage in sync with URL
            localStorage.setItem('marga_lang', urlLang);
        </script>
    </body>
</html>
