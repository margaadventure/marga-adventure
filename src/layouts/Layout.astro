---
import "../styles/global.css";
import Header from "../components/HeaderWrapper.astro";
import Footer from "../components/FooterWrapper.astro";
import ImageModal from "../components/ImageModal";

const {
    title,
    description = "Journey Inward, Explore Outward with Marga Adventure. Specialized in high-end trekking, spiritual retreats, and cultural tours in Nepal, Bhutan, and Tibet.",
    image = "/images/hero/hero-bg.webp",
    type = "website",
    headerVariant = "transparent",
    keywords = "trekking nepal, spiritual retreats, bhutan tours, tibet travel, marga adventure, luxury trekking, cultural tours, trekking népal, voyage spirituel, circuit bhoutan, voyage tibet, randonnée himalaya, agence voyage népal, guide francophone népal",
    robots = "index, follow",
    schema = null,
} = Astro.props;

const canonicalURL = new URL(
    Astro.url.pathname,
    Astro.site || "https://margaadventure.com",
);

const socialImageURL = new URL(image, Astro.url);

// Default JSON-LD
const organizationSchema = {
    "@context": "https://schema.org",
    "@type": "Organization",
    name: "Marga Adventure",
    url: "https://margaadventure.com",
    logo: "https://margaadventure.com/logo.webp",
    description:
        "Specialized in high-end trekking, spiritual retreats, and cultural tours in Nepal, Bhutan, and Tibet.",
    sameAs: [
        "https://www.facebook.com/margaadventure",
        "https://www.instagram.com/margaadventure",
    ],
    contactPoint: {
        "@type": "ContactPoint",
        telephone: "+9779700050945",
        contactType: "customer service",
        areaServed: ["NP", "BT", "CN-XZ", "FR", "BE", "CH"],
        availableLanguage: ["English", "French"],
    },
};
---

<!doctype html>
<html lang="en" class="scroll-smooth">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/png" href="/favicon.png" />
        <link rel="icon" type="image/webp" href="/favicon.webp" />
        <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="generator" content={Astro.generator} />
        <link rel="sitemap" href="/sitemap-index.xml" />

        <!-- Primary Meta Tags -->
        <title>{title} | Marga Adventure</title>
        <meta name="title" content={`${title} | Marga Adventure`} />
        <meta name="description" content={description} />
        <meta name="keywords" content={keywords} />
        <meta name="robots" content={robots} />
        <link rel="canonical" href={canonicalURL} />

        <!-- Open Graph / Facebook -->
        <meta property="og:type" content={type} />
        <meta property="og:url" content={canonicalURL} />
        <meta property="og:title" content={`${title} | Marga Adventure`} />
        <meta property="og:description" content={description} />
        <meta property="og:image" content={socialImageURL} />
        <meta property="og:site_name" content="Marga Adventure" />
        <meta property="og:locale" content="en_US" />
        <meta property="og:locale:alternate" content="fr_FR" />

        <!-- Twitter -->
        <meta property="twitter:card" content="summary_large_image" />
        <meta property="twitter:url" content={canonicalURL} />
        <meta property="twitter:title" content={`${title} | Marga Adventure`} />
        <meta property="twitter:description" content={description} />
        <meta property="twitter:image" content={socialImageURL} />
        <meta property="twitter:site" content="@margaadventure" />

        <!-- JSON-LD Schemas -->
        <script
            type="application/ld+json"
            set:html={JSON.stringify(organizationSchema)}
        />
        {
            schema && (
                <script
                    type="application/ld+json"
                    set:html={JSON.stringify(schema)}
                />
            )
        }
    </head><body class="bg-white text-gray-900 font-sans overflow-x-hidden">
        <a
            href="#main-content"
            class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 z-[200] bg-brand text-white px-4 py-2 rounded-md"
        >
            Skip to main content
        </a>
        <Header forceOpaque={headerVariant === "opaque"} />
        <ImageModal client:only="react" />
        <main id="main-content">
            <slot />
        </main>
        <a
            href="https://wa.me/9779700050945"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Chat with us on WhatsApp"
            class="fixed bottom-8 right-8 z-[100] flex items-center justify-center w-16 h-16 bg-[#25D366] rounded-full shadow-2xl hover:scale-110 transition-transform duration-300 group"
        >
            <svg
                class="w-9 h-9 text-white"
                fill="currentColor"
                viewBox="0 0 24 24"
                xmlns="http://www.w3.org/2000/svg"
                aria-hidden="true"
            >
                <path
                    d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"
                ></path>
            </svg>
            <span
                class="absolute right-full mr-4 bg-white text-black px-3 py-1 rounded-lg text-xs font-bold whitespace-nowrap opacity-0 group-hover:opacity-100 transition-opacity shadow-lg"
                >Chat with us</span
            >
        </a>
        <Footer />

        <script>
            // Lightweight image lightbox using event delegation (single listener)
            // This replaces the heavy MutationObserver approach that was causing 8-15s INP overhead
            document.addEventListener(
                "click",
                (e) => {
                    const target = e.target;
                    if (!target || !(target instanceof HTMLElement)) return;

                    // Check if clicked element is an image
                    const img =
                        target instanceof HTMLImageElement ? target : null;

                    // Skip if no image, or if image is inside a link/button, or has no-lightbox attribute
                    if (
                        !img ||
                        img.closest("button, a") ||
                        img.hasAttribute("data-no-lightbox")
                    ) {
                        return;
                    }

                    // Prevent default and open modal
                    e.preventDefault();
                    e.stopPropagation();

                    window.dispatchEvent(
                        new CustomEvent("open-image-modal", {
                            detail: img.src,
                        }),
                    );
                },
                { passive: false },
            ); // Non-passive only for preventDefault

            // Optional: Add keyboard support via focus (much lighter than attaching to all images)
            document.addEventListener("keydown", (e) => {
                const activeEl = document.activeElement;
                if (
                    (e.key === "Enter" || e.key === " ") &&
                    activeEl instanceof HTMLImageElement
                ) {
                    if (
                        !activeEl.closest("button, a") &&
                        !activeEl.hasAttribute("data-no-lightbox")
                    ) {
                        e.preventDefault();
                        window.dispatchEvent(
                            new CustomEvent("open-image-modal", {
                                detail: activeEl.src,
                            }),
                        );
                    }
                }
            });

            // Google Translate Integration
            const getCookie = (name: string): string | null => {
                const match = document.cookie.match(
                    new RegExp("(^| )" + name + "=([^;]+)"),
                );
                if (match) return match[2];
                return null;
            };

            const dispatchLanguageChange = (lang: string): void => {
                window.dispatchEvent(
                    new CustomEvent("language-changed", { detail: lang }),
                );
            };

            // Helper to check current language
            const getCurrentLang = () => {
                const cookie = getCookie("googtrans");
                if (cookie && cookie.includes("/fr")) {
                    return "fr";
                }
                return "en";
            };

            // Check initial state on load - Dispatch immediately and on load to be safe
            const initLang = getCurrentLang();
            dispatchLanguageChange(initLang);
            window.addEventListener("load", () => {
                dispatchLanguageChange(getCurrentLang());
            });

            window.addEventListener("trigger-translation-toggle", () => {
                const currentLang = getCurrentLang();
                const targetLang = currentLang === "fr" ? "en" : "fr";

                // Cookie-based toggling
                // We use 'auto' as the source language for better reliability

                if (targetLang === "en") {
                    // Aggressively clear cookies to revert to English
                    document.cookie =
                        "googtrans=; expires=Thu, 01 Jan 1970 00:00:00 UTC; path=/;";
                    document.cookie =
                        "googtrans=; expires=Thu, 01 Jan 1970 00:00:00 UTC; path=/; domain=" +
                        window.location.hostname;
                    document.cookie =
                        "googtrans=; expires=Thu, 01 Jan 1970 00:00:00 UTC; path=/; domain=." +
                        window.location.hostname;
                } else {
                    // Set cookie to force French translation (/auto/fr)
                    document.cookie = "googtrans=/auto/fr; path=/;";
                    document.cookie =
                        "googtrans=/auto/fr; path=/; domain=" +
                        window.location.hostname;
                    document.cookie =
                        "googtrans=/auto/fr; path=/; domain=." +
                        window.location.hostname;
                }

                // Give the browser a moment to persist the cookie before reloading
                setTimeout(() => {
                    window.location.reload();
                }, 100);
            });
        </script>

        <!-- Google Translate Widget (Hidden but active) -->
        <div
            id="google_translate_element"
            style="position:absolute; width:1px; height:1px; overflow:hidden; clip:rect(0,0,0,0); white-space:nowrap; border:0; padding:0; margin:-1px;"
        >
        </div>

        <!-- Google Translate - Deferred Loading to prevent breaking React -->
        <script type="text/javascript" is:inline>
            // Define the callback globally BEFORE loading the script
            function googleTranslateElementInit() {
                new google.translate.TranslateElement(
                    {
                        pageLanguage: "en",
                        includedLanguages: "en,fr",
                        autoDisplay: false,
                        layout: google.translate.TranslateElement.InlineLayout
                            .SIMPLE,
                    },
                    "google_translate_element",
                );
                console.log("✅ Google Translate initialized");
            }

            // Defer loading Google Translate to prevent breaking React hydration
            function loadGoogleTranslate() {
                // Only load if not already loaded
                if (window.google && window.google.translate) {
                    console.log("Google Translate already loaded");
                    return;
                }

                console.log("Loading Google Translate script...");
                const script = document.createElement("script");
                script.type = "text/javascript";
                script.src =
                    "//translate.google.com/translate_a/element.js?cb=googleTranslateElementInit";
                script.async = true;
                document.body.appendChild(script);
            }

            // Wait for everything to be ready before loading Google Translate
            // This ensures React has hydrated and event listeners are attached
            if (document.readyState === "complete") {
                // Page already loaded, wait a bit more for React
                setTimeout(loadGoogleTranslate, 2000);
            } else {
                window.addEventListener("load", function () {
                    // Wait 2 seconds after load for React to fully hydrate
                    setTimeout(loadGoogleTranslate, 2000);
                });
            }
        </script>

        <style is:global>
            /* Hide Google Translate Toolbar */
            .goog-te-banner-frame.skiptranslate {
                display: none !important;
            }
            body {
                top: 0px !important;
            }
            /* Hide Google Translate Tooltips */
            .goog-tooltip {
                display: none !important;
            }
            .goog-te-gadget-icon {
                display: none !important;
            }
            /* Hide Google Translate elements that might block clicks */
            .goog-te-menu-frame,
            .goog-te-menu2,
            .goog-te-balloon-frame,
            #goog-gt-tt,
            .goog-te-spinner-pos,
            .goog-te-ftab-float {
                display: none !important;
            }
            iframe.goog-te-menu-frame,
            iframe.goog-te-banner-frame {
                display: none !important;
            }
            /* Google Translate sometimes adds font elements that interfere */
            font[style*="background-color"] {
                background-color: transparent !important;
            }
        </style>
    </body>
</html>
