---
import Layout from "../layouts/Layout.astro";
import ActivityPage from "../components/ActivityPage";
import trekking1 from "../assets/images/activities/trekking/congde-tekking_1.webp";
import trekking2 from "../assets/images/activities/trekking/Thamserku-trekiking_2.webp";
import trekking3 from "../assets/images/activities/trekking/manewall-trekking_3.webp";
import bg from "../assets/images/activities/trekking/background.webp";
---

<Layout
    title="Trekking"
    description="Walk the ridges of the Himalayas. Our trekking packages take you deep into the heart of the mountains, combining physical challenge with cultural immersion."
    image={trekking1.src}
    keywords="Nepal trekking, Himalaya trekking packages, luxury trekking Nepal, Manaslu trek, Langtang valley trek"
>
    <ActivityPage
        title="Sacred Steps in the Himalayas"
        subtitle="Trekking & Culture"
        description="Walk the ancient ridges where the mountains embrace the sky and stone paths tell stories of a thousand years. Here, the journey is measured not in miles, but in the warmth of shared smiles and the hiss of steam from a village tea hearth. Blend the thrill of the ascent with the deep peace of temple chants. In Nepal, every step draws you closer to the clouds, and every encounter brings you closer to home."
        heroImage={bg.src}
        highlights={[
            { text: "Manaslu Circuit", link: "/trekking/manaslu-circuit" },
            { text: "Langtang Valley", link: "/trekking/langtang-valley" },
            { text: "Upper Mustang", link: "/trekking/upper-mustang" },
            { text: "Mohare Danda", link: "/trekking/mohare-danda" },
        ]}
        galleryImages={[trekking1.src, trekking2.src, trekking3.src]}
        overlayOpacity="bg-black/10"
        client:visible
    />
</Layout>
