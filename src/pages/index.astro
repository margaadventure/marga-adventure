---
import Layout from "../layouts/Layout.astro";
import HomeContent from "../components/HomeContent";
import { getImage } from "astro:assets";
import heroBg from "../assets/images/hero/hero-bg.webp";
import nepalMap from "../assets/images/maps/nepal-map.webp";
import { JOURNEY_CATEGORIES } from "../constants";

const heroWidths = [640, 750, 828, 1080, 1280, 1600, 1920, 2560];
const heroOptimized = await Promise.all(
	heroWidths.map((w) =>
		getImage({
			src: heroBg,
			format: "webp",
			width: w,
			quality: 75,
		}),
	),
);

const heroSrcSet = heroOptimized
	.map((img) => `${img.src} ${img.attributes.width}w`)
	.join(", ");
const heroLg =
	heroOptimized.find((img) => img.attributes.width === 1920) ||
	heroOptimized[heroOptimized.length - 1];

const mapSm = await getImage({
	src: nepalMap,
	format: "webp",
	width: 800,
	quality: 60,
});
const mapLg = await getImage({
	src: nepalMap,
	format: "webp",
	width: 1600,
	quality: 60,
});
const nepalMapSrcSet = `${mapSm.src} 800w, ${mapLg.src} 1600w`;

const optimizedJourneyCategories = await Promise.all(
	JOURNEY_CATEGORIES.map(async (cat) => {
		const optimizedImages = await Promise.all(
			cat.images.map(async (img: any) => {
				const sm = await getImage({
					src: img,
					format: "webp",
					width: 600,
					quality: 60,
				});
				const lg = await getImage({
					src: img,
					format: "webp",
					width: 1200,
					quality: 60,
				});
				return {
					src: lg.src,
					srcSet: `${sm.src} 600w, ${lg.src} 1200w`,
				};
			}),
		);
		return { ...cat, images: optimizedImages };
	}),
);
---

<Layout
	title="Home"
	description="Welcome to Marga Adventure. An exclusive gateway to the Himalayas, offering premium trekking, spiritual retreats, and cultural experiences in Nepal, Bhutan, and Tibet."
	keywords="Nepal trekking, Bhutan tours, Tibet travel, luxury adventure, spiritual retreats, Himalaya trekking, Marga Adventure"
	image={heroLg.src}
>
	<HomeContent
		client:idle
		heroImageSrc={heroLg.src}
		heroImageSrcSet={heroSrcSet}
		nepalMapSrc={mapLg.src}
		nepalMapSrcSet={nepalMapSrcSet}
		journeyCategories={optimizedJourneyCategories}
	/>
</Layout>
