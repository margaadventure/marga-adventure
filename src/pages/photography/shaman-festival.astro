---

<Layout
    title="Shaman Festival Photography"
    description="A rare photographic journey into the heart of Kham Magar mysticism in Lukum Village. Capture the ancient Shaman Festival and its unique rituals."
>
    <ExpeditionSpecialLayout
        title="Shaman Festival"
        overview={overview}
        images={images}
        highlights={highlights}
        features={features}
        tripStats={{
            destination: "East Rukum, Nepal",
            difficulty: "Moderate",
            groupSize: "4-8 People",
            season: "Mid-July",
        }}
        client:visible
    />
</Layout>
