---
import Layout from "../../layouts/Layout.astro";
import TripItineraryPage from "../../components/TripItineraryPage";

const itinerary = [
    {
        day: "Day 1",
        title: "Arrival and transfer to hotel",
        description:
            'Arrive in Kathmandu and transfer to your hotel. Use this day to acclimatize and capture your first impressions of the city. Focus on the chaotic, vibrant streets of Thamel, capturing the interplay of rickshaws, prayer flags, and shop lights. The "blue hour" provides a moody, atmospheric backdrop for street photography, allowing you to experiment with low-light settings and ISO limits amidst the urban bustle.',
        stats: {},
    },
    {
        day: "Day 2",
        title: "Visit Patan, Swayambhunath, and Pashupatinath temple",
        description:
            "Start with the intricate golden details and Newari architecture of Patan Durbar Square, focusing on symmetry and textures. Move to Swayambhunath for wide-angle shots of the valley and playful environmental portraits of the resident monkeys backlit by the sun. End at Pashupatinath to capture the intense, spiritual atmosphere of the cremation ghats and the dramatic fire lighting of the evening Aarti ceremony using a fast prime lens.",
        stats: {},
    },
    {
        day: "Day 3",
        title: "Boudhanath and Shechen Monastery Tsechu Festival",
        description:
            "Begin with the symmetry of the colossal Boudhanath Stupa, photographing pilgrims performing kora. Move to Shechen Monastery for the Tsechu Festival. Focus on freezing the motion of the cham (masked) dancers in their vibrant brocade costumes. Use a telephoto lens to isolate specific masks and gestures against the crowd, capturing the intensity of the rituals and the rich colors of the monastery courtyard.",
        stats: {},
    },
    {
        day: "Day 4",
        title: "Travel to Bhaktapur, Bisket Jatra",
        description:
            "A living museum of medieval art. As the Bisket Jatra begins, document the assembly of the massive wooden chariot. Focus on the raw textures of the wood and the anticipation in the crowd. The car-free alleyways provide a timeless backdrop for street portraits of locals in traditional Newari attire. Look for high vantage points to capture the scale of the gathering crowds.",
        stats: {},
    },
    {
        day: "Day 5",
        title: "Bhaktapur Bisket Jatra",
        description:
            "Immerse yourself in the high energy of the festival. Today is about action photography. Use a fast shutter speed to freeze the chaotic tug-of-war between the upper and lower city residents pulling the chariot. Capture the raw emotions—exhilaration, strain, and devotion—on the faces of the participants. Wide shots are essential here to convey the magnitude of the chariot against the tiered pagoda temples.",
        stats: {},
    },
    {
        day: "Day 6",
        title: "Bhaktapur Bisket Jatra - The Climax",
        description:
            'Focus on the climax of the festival, often involving the raising of the Yashin (ceremonial pole) or the "Sindoor Jatra" (vermilion powder) celebrations in nearby Thimi if accessible. Look for the explosion of orange powder creating a hazy, dreamlike atmosphere. The contrast of the vibrant red powder against the ancient brick architecture is visually striking. Backlight the dust and powder to create dramatic, ethereal silhouettes.',
        stats: {},
    },
    {
        day: "Day 7",
        title: "Drive to Chitwan",
        description:
            "The drive to the lowlands offers a shift in landscape photography. Capture the winding Trishuli River and highway life from the window. As you descend into the Terai plains, the light softens. Photograph the traditional mud-walled Tharu village architecture. The golden hour sun setting over the flat mustard fields offers a stark, serene contrast to the hill landscapes you just left.",
        stats: {
            duration: "5-6 hrs drive",
        },
    },
    {
        day: "Day 8",
        title: "Chitwan, Jungle Safari",
        description:
            "Switch to your longest telephoto lens for wildlife. Early morning mist over the Rapti River creates moody, atmospheric shots. Look for the texture of armored rhino skin, the vibrant plumage of peacocks, and the stealth of crocodiles. The jungle light changes rapidly; be ready for high-contrast shots in the dense canopy and soft, warm light in the tall elephant grass.",
        stats: {},
    },
    {
        day: "Day 9",
        title: "Drive to Bandipur",
        description:
            "Bandipur is a gem for street photography without the chaos. Focus on the beautifully preserved 18th-century architecture and car-free streets. Capture the warm tones of the Newari houses and the brilliant magenta bougainvillea against wood carvings. The ridge offers spectacular sunset silhouettes of the Himalayan range if the weather is clear, perfect for panoramic stitching.",
        stats: {
            duration: "3-4 hrs drive",
        },
    },
    {
        day: "Day 10",
        title: "Drive to Pokhara",
        description:
            "The drive offers scenic valley views, but the highlight awaits in Pokhara. Head immediately to the lakeside. Photograph the colorful wooden doonga boats reflecting in Phewa Lake. The golden hour illuminates the sharp peak of Mt. Machhapuchhre (Fishtail), creating a perfect mirror image in the water. It is an ideal time for serene landscape shots and long exposure water photography.",
        stats: {
            duration: "2-3 hrs drive",
        },
    },
    {
        day: "Day 11",
        title: "Drive to Ghandruk",
        description:
            "This journey takes you up close to the peaks. Photograph the rugged terrain and terraced millet fields along the off-road track. Ghandruk offers stunning cultural portraits of the Gurung people and their slate-roofed stone houses. The primary goal is the sunset hitting Annapurna South and Hiunchuli; use a tripod to capture the alpenglow turning the massive snow peaks into gold.",
        stats: {
            duration: "3-4 hrs drive",
        },
    },
    {
        day: "Day 12",
        title: "Drive back to Pokhara",
        description:
            "Wake up before dawn for the sunrise over the mountains; the changing light on the peaks is unmissable. On the return drive, capture the daily life of mountain communities. Back in Pokhara, hike or drive to the World Peace Pagoda for a wide-angle shot of the entire valley, the lake, and the Annapurna range in a single, majestic frame.",
        stats: {
            duration: "3 hrs drive",
        },
    },
    {
        day: "Day 13",
        title: "Fly back to Kathmandu",
        description:
            "You will get an opportunity to take aerial shots of the Himalayas. Back in Kathmandu, dive into the sensory overload of the Ason market and the ancient royal palace of Kathmandu. Focus on the vibrant spices, textures of goods, and the hustle of trade. It is perfect for gritty, high-contrast street photography, capturing the city's pulse and the clash of ancient commerce with modern life.",
        stats: {
            duration: "25 min flight",
        },
    },
    {
        day: "Day 14",
        title: "Departure",
        description:
            "Use these final hours for detail-oriented shots—textures of prayer wheels, close-ups of artifacts, or quiet street scenes near your hotel. Review your image portfolio as you head to the airport, ensuring you have captured the diverse essence of Nepal, from the high Himalayas and dense jungles to the chaotic energy of its ancient festivals.",
        stats: {},
    },
];

const highlights = [
    {
        title: "Shechen Monastery Tsechu",
        description:
            "Capture the vibrant Cham (masked) dances and intricate brocade costumes in a spiritual setting.",
    },
    {
        title: "Bisket Jatra Festival",
        description:
            "Freeze the raw action and emotion of the massive chariot tug-of-war in Bhaktapur.",
    },
    {
        title: "Spiritual Kathmandu",
        description:
            "Photograph atmospheric silhouettes at Swayambhunath and dramtic Aarti fire lighting.",
    },
    {
        title: "Chitwan Wildlife",
        description:
            "Shoot rhinos and birdlife through the mystical morning mist of the Rapti River.",
    },
    {
        title: "Bandipur Street Scenes",
        description:
            "Frame timeless Newari architecture and car-free streets against a Himalayan backdrop.",
    },
    {
        title: "Pokhara Reflections",
        description:
            "Capture mirror-image perfection of Mt. Machhapuchhre on Phewa Lake at dawn.",
    },
];

const overview = `This photography trip offers a comprehensive visual journey through Nepal’s diverse landscapes and vibrant traditions. You will document the spiritual intensity of Tsechu festival at Shechen Monastery and the chaotic energy of Bhaktapur's Bisket Jatra festival.
The trip transitions to the misty jungles of Chitwan for wildlife shots, the preserved architecture of Bandipur, and majestic Annapurna views from Ghandruk. It is a perfect blend of portraiture, action, wildlife, and landscape photography designed for the visual storyteller.`;
const packingList = [
    {
        category: "Camera Gear",
        items: [
            "Full-frame DSLR/Mirrorless Body (plus a backup body)",
            "Wide-angle Lens (16-35mm) for landscapes and architecture",
            "Telephoto Lens (70-200mm or 100-400mm) for wildlife and portraits",
            "Fast Prime Lens (35mm or 50mm f/1.8) for low light & street",
            "Sturdy Tripod for landscapes and low-light shots",
            "ND & Polarizer Filters",
            "Extra Batteries & Memory Cards (cold drains batteries fast)",
        ],
    },
    {
        category: "Clothing & Essentials",
        items: [
            "Warm Layers (Down Jacket, Fleece) for mornings",
            "Comfortable Walking Shoes",
            "Lightweight Rain Jacket",
            "Dust Mask / Buff for dusty roads",
            "Headlamp for early morning starts",
        ],
    },
];

import bgImage from "../../assets/images/activities/photography/Bisket Jatra.webp";
---

<Layout
    title="Tshechu Festival & Bisket Jatra Photography Tour | Marga Adventure"
    image={bgImage.src}
    keywords="Tshechu Festival photography, Bisket Jatra Nepal, Bhaktapur festival, Buddhist festival photography, cultural tours Nepal"
>
    <TripItineraryPage
        title="Tshechu Festival & Bisket Jatra"
        subtitle="A Visual Pilgrimage"
        heroImage={bgImage.src}
        overview={overview}
        highlights={highlights}
        itinerary={itinerary}
        tripStats={{
            duration: "14 Days",
            maxAltitude: "Culture / Photo",
            maxAltitudeLabel: "Trip Type",
            difficulty: "Moderate",
            groupSize: "2-10",
        }}
        showElevationGraph={false}
        packingList={packingList}
        client:visible
    />
</Layout>
