---
import Layout from "../layouts/Layout.astro";
import ActivityPage from "../components/ActivityPage";
import wildlife1 from "../assets/images/activities/wildlife/deer-wildlife.jpg";
import peacock from "../assets/images/activities/wildlife/jungle-wildlife.jpg";
import wildlife3 from "../assets/images/activities/wildlife/monkey.jpg";
import bg from "../assets/images/activities/wildlife/wildlife-hero.jpg";
---

<Layout
    title="Wildlife"
    description="Encounter the wild side of Nepal. Home to Bengal Tigers, One-Horned Rhinos, and elusive Snow Leopards, our wildlife tours bring you face-to-face with nature's majesty."
    image={wildlife1.src}
    keywords="Nepal wildlife tour, tiger tracking Nepal, snow leopard expedition, rhino safari Chitwan, birdwatching Nepal"
>
    <ActivityPage
        title="Wildlife Encounters"
        subtitle="Wildlife & Nature"
        description="Venture into the untamed heart of Nepal, where dense jungles and grassy plains teem with exotic life. Beyond the high peaks lies a world of roaring Bengal Tigers, grazing One-Horned Rhinos, and playful herds of wild elephants. Our wildlife experiences take you deep into protected national parks, offering a chance to witness nature's drama unfold in its purest form. From canoe rides on crocodile-infested rivers to silent jungle walks, discover a biodiversity hotspot that rivals any in Asia."
        heroImage={bg.src}
        overlayOpacity="bg-black/20"
        highlights={[
            { text: "Snow Leopard Tracking", link: "/wildlife/snow-leopard" },
            { text: "Red Panda Tracking", link: "/wildlife/red-panda" },
            { text: "Birdwatching", link: "/wildlife/kathmandu-koshi-birding" },
            {
                text: "Chitwan & Bardia Expedition",
                link: "/wildlife/chitwan-bardia-expedition",
            },
        ]}
        galleryImages={[wildlife1.src, peacock.src, wildlife3.src]}
        client:visible
    />
</Layout>
