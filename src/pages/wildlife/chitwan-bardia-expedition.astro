---
import Layout from "../../layouts/Layout.astro";
import ActivityPage from "../../components/ActivityPage";
import TripItineraryPage from "../../components/TripItineraryPage";
import crocodile from "../../assets/images/activities/wildlife/crocodile.jpg";
import peacock from "../../assets/images/activities/wildlife/peacock.jpg";

const overview = `Experience the ultimate wildlife expedition across Nepal’s Terai lowlands, journeying from the accessible jungles of Chitwan to the remote wilderness of Bardia. This adventure offers intimate encounters with endangered One-horned Rhinos and elusive Royal Bengal Tigers in their natural habitats. Between safaris, explore the spiritual birthplace of Lord Buddha in Lumbini. Combining jeep drives, river floats, and jungle walks, this itinerary promises a comprehensive immersion into Nepal's diverse ecosystems and rich cultural heritage.`;

const highlights = [
    // ... (start of highlights)

    {
        title: "Chitwan’s Rhino Sanctuary",
        description:
            "Track the endangered One-horned Rhinoceros and observe bathing elephants in the accessible jungles of Nepal's first national park.",
    },
    {
        title: "Riverine Reptiles",
        description:
            "Drift down the Narayani River to spot critically endangered Gharial crocodiles and Marsh-Muggers basking on sandy banks.",
    },
    {
        title: "Spiritual Interlude",
        description:
            "Visit Lumbini, the birthplace of Lord Buddha, and witness the rare Sarus Crane in its sacred sanctuary.",
    },
    {
        title: "Bardia’s Tiger Territory",
        description:
            "Explore the remote and pristine Karnali floodplains, offering the highest probability of sighting the elusive Royal Bengal Tiger.",
    },
    {
        title: "Rare Aquatic Life",
        description:
            "Scan the Karnali River waters for a glimpse of the shy and endangered Gangetic river dolphin.",
    },
    {
        title: "Multi-Mode Safaris",
        description:
            "Experience the jungle from every angle with diverse activities including jeep drives, dugout canoe floats, and guided nature walks.",
    },
];

const itinerary = [
    {
        day: "Day 1",
        title: "Arrival in Kathmandu",
        description:
            "Arrive at Tribhuvan International Airport where you will be greeted and transferred to your hotel in the city center. Spend your afternoon acclimating to the capital or exploring its famous cultural heritage sites, including the great stupas of Pashupatinath and Boudhanath. While primarily a cultural day, the lush temple grounds often host monkeys and diverse bird species, offering a small introduction to the country's biodiversity before your jungle adventure begins.",
    },
    {
        day: "Day 2",
        title: "Fly to Chitwan and Jungle Introduction",
        description:
            "Take a short flight to Bharatpur and drive to your jungle lodge. After settling in, immerse yourself in the natural surroundings. The afternoon features a walking safari to the Narayani River, a prime location to observe elephants bathing and frolic in the water. This peaceful walk introduces you to the riverine ecosystem, offering excellent opportunities to spot various bird species and enjoy the golden hour over the jungle.",
    },
    {
        day: "Day 3",
        title: "Full-Day Jungle & River Safari",
        description:
            "Embark on a comprehensive full-day safari. Begin by crossing the river to enter the core of the National Park. Utilize a jeep to scout the undergrowth for tigers, then transition to foot for a quiet approach to camouflaged hides. Here, you will patiently wait for varied wildlife, including rhinos and jungle cats. The day concludes with a drive through the Sal forests, searching for sloth bears and wild boars before returning to camp.",
    },
    {
        day: "Day 4",
        title: "River Float and Deep Jungle Drive",
        description:
            "Start the day with a serene boat safari on the Narayani River. Drift past gentle rapids while searching for the critically endangered Gharial crocodile and the Marsh-Mugger. The riverbanks are teeming with aquatic birdlife. In the afternoon, venture deep into the park on a jeep safari. Your naturalist guide will help track the elusive Royal Bengal Tiger and the One-horned Rhinoceros, along with herds of deer and troupes of monkeys.",
    },
    {
        day: "Day 5",
        title: "Drive to Lumbini & Crane Sanctuary",
        description:
            "Drive three hours to Lumbini, the birthplace of Buddha. Beyond its spiritual significance, the region is a haven for birdwatchers. Visit the Lumbini Crane Sanctuary to spot the rare and elegant Sarus Crane. As you tour the sacred gardens and wetlands, keep your binoculars ready for Eurasian Wigeons, Marsh Harriers, and Booted Eagles, offering a perfect blend of cultural history and ornithology.",
    },
    {
        day: "Day 6",
        title: "Overland Journey to Bardia National Park",
        description:
            "Travel across the southern floodplains of the Terai, passing through rural landscapes and forests. As you approach Bardia, the wilderness becomes more pristine. The journey includes a crossing of the Babai River, a known habitat for Marsh Mugger crocodiles often seen warming themselves in the sun. Upon arrival at your lodge, relax and prepare for the intense wildlife encounters that the far-western region offers.",
    },
    {
        day: "Day 7",
        title: "Karnali River Safari & Wilderness",
        description:
            "Drive Enjoy a morning river safari on the Karnali, Nepal's longest river. Float downstream to spot aquatic birds, crocodiles, and, if fortunate, the extremely rare Gangetic river dolphin. In the afternoon, when animals are most active, embark on a jeep safari. Bardia offers some of the best chances to spot the Royal Bengal Tiger in the wild, alongside wild elephants and rhinos in a dense, uncrowded habitat.",
    },
    {
        day: "Day 8",
        title: "Full-Day Tiger Tracking",
        description:
            "Dedicate the entire day to tracking the Royal Bengal Tiger. An early start allows you to explore the park's deep jungle, utilizing various lookouts and hides to maximize sighting opportunities. Your guide will interpret jungle calls and signs while you observe the rich biodiversity of the park. The day also includes a visit to the Gharial breeding center to learn about the conservation of these unique reptiles.",
    },
    {
        day: "Day 9",
        title: "Flight to Kathmandu",
        description:
            "After a leisurely breakfast, drive to Nepalgunj airport for your return flight. Keep a final watch for Gharials or crocodiles as you cross the river one last time. Upon landing in Kathmandu, transfer to your hotel. The evening is yours to relax or explore the city's dining scene, reflecting on the diverse species and habitats encountered during your journey through the Terai lowlands.",
    },
    {
        day: "Day 10",
        title: "International Departure",
        description:
            "Enjoy a leisurely morning before your transfer to the international airport. Depending on your flight time, you may have a final chance to observe the urban wildlife of the Kathmandu Valley before departing.",
    },
];

const images = [crocodile.src, peacock.src];

const packingList = [
    {
        category: "Clothing",
        items: [
            "Lightweight, neutral-colored clothing (greens, browns, tans) for jungle walks",
            "Long-sleeved shirts and trousers to protect against sun and insects",
            "Warm layers for cool mornings and evenings, especially during winter (Nov-Feb)",
            "Comfortable walking shoes or hiking boots",
            "Sandals or flip-flops for around the lodge",
            "Hat or cap for sun protection",
        ],
    },
    {
        category: "Gear & Accessories",
        items: [
            "Binoculars (essential for wildlife viewing and birdwatching)",
            "Camera with zoom lens and spare batteries",
            "Sunscreen and sunglasses",
            "Insect repellent",
            "Reusable water bottle",
            "Small daypack for carrying essentials during safaris",
        ],
    },
    {
        category: "Documents & Personal",
        items: [
            "Passport and necessary permits (arranged by us)",
            "Personal medication and first aid kit",
            "Travel insurance details",
        ],
    },
];
---

<Layout
    title="Chitwan & Bardia Wildlife Expedition"
    image={images[0]}
    keywords="Chitwan jungle safari, Bardia tiger tracking, Nepal wildlife tour, rhino watching Nepal, Gharial crocodile safari"
>
    <TripItineraryPage
        title="Chitwan & Bardia Wildlife Expedition"
        heroImage={images[0]}
        overview={overview}
        highlights={highlights}
        itinerary={itinerary}
        packingList={packingList}
        showElevationGraph={false}
        tripStats={{
            duration: "10 Days",
            maxAltitude: "150m", // Lowlands
            difficulty: "Easy",
            groupSize: "2-8 ",
            maxAltitudeLabel: "Avg Elevation",
        }}
        client:load
    />
</Layout>
