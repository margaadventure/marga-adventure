---
import Layout from "../../layouts/Layout.astro";
import ActivityPage from "../../components/ActivityPage";
import birdWatchingBg from "../../assets/images/activities/wildlife/birdwatching-hero.jpg";
import bird3 from "../../assets/images/activities/wildlife/bird-3.jpg";
import peacock from "../../assets/images/activities/wildlife/peacock.jpg";
import bird2 from "../../assets/images/activities/wildlife/bird-2.jpg";
---

<Layout
    title="Birdwatching"
    description="Spot the rare avian wonders of Nepal. With over 850 species, including the Spiny Babbler, our birdwatching tours are a paradise for naturalists."
    image={bird3.src}
    keywords="Birdwatching Nepal, Himalayan birds, Koshi Tappu birding, Spiny Babbler, Nepal ornithology tour, bird photography Nepal"
>
    <ActivityPage
        title="Wings Over the Himalayas"
        subtitle="Birdwatching"
        description="Embark on a birdwatching journey through Nepal, a hidden sanctuary boasting over 900 avian species. From the tropical wetlands of Koshi Tappu to the alpine forests of the Annapurna region, this small nation offers a rare density of diverse habitats. Spot the endemic Spiny Babbler, the gleaming Himalayan Monal, and vast flocks of migratory waterfowl. Whether you are a casual birder or a seasoned ornithologist, the Himalayan skies promise sightings that will leave you breathless."
        heroImage={birdWatchingBg.src}
        highlights={[
            {
                text: "Kathmandu & Koshi Tappu Expedition",
                link: "/wildlife/kathmandu-koshi-birding",
            },
        ]}
        galleryImages={[bird3.src, peacock.src, bird2.src]}
        client:visible
    />
</Layout>
