---
export function getStaticPaths() {
  return [{ params: { lang: 'en' } }, { params: { lang: 'fr' } }];
}

import { useAstroI18n } from "../../i18n/astro";
import Layout from "../../layouts/Layout.astro";
import { I18nActivityShell } from "../../components/I18nActivityShells";
import wildlife1 from "../../assets/images/activities/wildlife/deer-wildlife.webp";
import peacock from "../../assets/images/activities/wildlife/jungle-wildlife.webp";
import wildlife3 from "../../assets/images/activities/wildlife/monkey.webp";
import bg from "../../assets/images/activities/wildlife/wildlife-hero.webp";
import type { Locale } from "../../i18n/i18n";
const { t, tTrip, dict, enDict } = await useAstroI18n(Astro.url);
const lang = Astro.params.lang as Locale;
---
<Layout
    title={t("nav.wildlifeMetaTitle")}
    description={t("nav.wildlifeMetaDesc")}
    image={wildlife1.src}
    keywords={lang === 'en' ? "Nepal wildlife tour, tiger tracking Nepal, snow leopard expedition, rhino safari Chitwan, birdwatching Nepal" : "Circuit animalier Népal, pistage tigres Népal, expédition léopard des neiges, safari rhinocéros Chitwan, observation oiseaux Népal"}
>
    <I18nActivityShell
        title={t("nepal.act3Title")}
        titleKey="nepal.act3Title"
        subtitle={t("nav.wildlifeSubtitle")}
        description={t("nav.wildlifeDescription")}
        heroImage={bg.src}
        overlayOpacity="bg-black/20"
        highlights={[
            { text: tTrip("wildlife.birdwatching"), link: `/${lang}/wildlife/kathmandu-koshi-birding` },
            { text: tTrip("wildlife.chitwan-bardia-expedition.title"), link: `/${lang}/wildlife/chitwan-bardia-expedition` },
            { text: tTrip("wildlife.snow-leopard.title"), link: `/${lang}/wildlife/snow-leopard` },
            { text: tTrip("wildlife.red-panda.title"), link: `/${lang}/wildlife/red-panda` },
        ]}
        galleryImages={[wildlife1.src, peacock.src, wildlife3.src]}
        client:visible
     initialLocale={lang}
     initialDict={dict}
     initialFallbackDict={enDict} />
</Layout>
