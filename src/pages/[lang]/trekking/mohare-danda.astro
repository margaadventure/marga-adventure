---
export function getStaticPaths() {
  return [{ params: { lang: 'en' } }, { params: { lang: 'fr' } }];
}

import { useAstroI18n } from "../../../i18n/astro";
import Layout from "../../../layouts/Layout.astro";
import TripItineraryPage from "../../../components/TripItineraryPage";
import mohareImg from "../../../assets/images/activities/trekking/mohare-Danda_trekking.webp";
import type { Locale } from "../../../i18n/i18n";

const { t, tripData: tripDataFn, dict } = await useAstroI18n(Astro.url);
const lang = Astro.params.lang as Locale;

const td = tripDataFn("trekking.mohare-danda") as any;
---
<Layout
    title={td.title}
    image={mohareImg.src}
    keywords="Mohare Danda Trek, eco community trek Nepal, Annapurna panorama trek, sustainable trekking Nepal, Magar culture homestay"
>
    <TripItineraryPage
        title={td.title}
        subtitle={td.subtitle}
        heroImage={mohareImg.src}
        overview={td.overview}
        highlights={td.highlights}
        itinerary={td.itinerary}
        tripStats={{
            duration: td.duration,
            maxAltitude: td.maxAltitude,
            difficulty: td.difficulty,
            groupSize: td.groupSize,
        }}
        client:load
     initialLocale={lang}
     initialDict={dict} />
</Layout>
