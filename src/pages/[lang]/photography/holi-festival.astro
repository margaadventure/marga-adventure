---
export function getStaticPaths() {
  return [{ params: { lang: 'en' } }, { params: { lang: 'fr' } }];
}

import { useAstroI18n } from "../../../i18n/astro";
import Layout from "../../../layouts/Layout.astro";
import ExpeditionSpecialLayout from "../../../components/ExpeditionSpecialLayout";

import holiImg1 from "../../../assets/images/activities/photography/holi 1.webp";
import holiImg2 from "../../../assets/images/activities/photography/holi 2.webp";
import type { Locale } from "../../../i18n/i18n";

const { t, tripData, dict } = await useAstroI18n(Astro.url);
const lang = Astro.params.lang as Locale;

// Fetch trip data from trips.json
const trip = tripData("photography.holi");
---
<Layout
    title={trip.title}
    image={holiImg1.src}
    keywords="Holi Festival photography, Fagu Purnima Nepal, Kathmandu festival photography, cultural photography tour, Nepal festivals"
>
    <ExpeditionSpecialLayout
        title={trip.title}
        overview={trip.overview}
        images={[holiImg1.src, holiImg2.src]}
        highlights={trip.highlights}
        features={trip.features}
        tripStats={{
            destination: "Kathmandu Valley",
            difficulty: t("trip.easy"),
            groupSize: "4-10",
            season: "March (Spring)",
        }}
        client:load
        initialLocale={lang}
        initialDict={dict}
    />
</Layout>
