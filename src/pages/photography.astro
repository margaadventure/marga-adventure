---
import Layout from "../layouts/Layout.astro";
import ActivityPage from "../components/ActivityPage";
import photo1 from "../assets/images/activities/photography/photography_prayers.jpg";
import photo2 from "../assets/images/activities/photography/Photography 1_.jpg";
import photo3 from "../assets/images/activities/photography/machhapuchare-photography_3.jpg";
import photo4 from "../assets/images/activities/photography/photography_mask.jpg";
import heroBg from "../assets/images/activities/photography/photography-hero-bg.jpg";
---

<Layout
    title="Photography Trips"
    description="Capture the light of the Himalayas. Designed for photographers, these trips chase the golden hour over Everest and the shadows of ancient temples."
    image={photo1.src}
    keywords="Nepal photography tours, Himalaya photography, cultural photography Nepal, wildlife photography Nepal, festival photography tours"
>
    <ActivityPage
        title="Chasing Light in the Himalayas"
        subtitle="Photography Trip"
        description="Nepal is a living masterpiece painted in amber dawn and indigo shadow. Frame the fiery light igniting the peaks and the mist-shrouded temples where time stands still. From the haunting gaze of a Sadhu to the raw power of a Bengal tiger, every shutter click captures a story of resilience.This is a visual pilgrimage into the soul of the Himalayas."
        heroImage={heroBg.src}
        highlights={[
            {
                text: "Tshechu & Bisket Jatra ",
                link: "/photography/tshechu-festival-bisket-jatra",
            },
            {
                text: "Tiji Festival Mustang",
                link: "/photography/mustang-chitwan-expedition",
            },
            {
                text: "Holi Photography ",
                link: "/photography/holi-festival",
            },
            {
                text: "Shaman Festival",
                link: "/photography/shaman-festival",
            },
        ]}
        galleryImages={[photo1.src, photo2.src, photo4.src]}
        client:visible
    />
</Layout>
