---
import Layout from "../layouts/Layout.astro";
import ActivityPage from "../components/ActivityPage";
import photo1 from "../assets/images/activities/photography/Sadhu-photography_1.jpg";
import photo2 from "../assets/images/activities/photography/potrait-photography_2.jpg";
import photo3 from "../assets/images/activities/photography/machhapuchare-photography_3.jpg";
import photo4 from "../assets/images/activities/photography/potratit-photography_4.jpg";
import heroBg from "../assets/images/activities/photography/photography-hero-bg.jpg";
---

<Layout
    title="Photography Trips"
    description="Capture the light of the Himalayas. Designed for photographers, these trips chase the golden hour over Everest and the shadows of ancient temples."
    image={photo1.src}
>
    <ActivityPage
        title="Chasing Light in the Himalayas"
        subtitle="Photography Trip"
        description="Nepal is a living masterpiece painted in light and shadow. Frame the golden dawn igniting the himalayan peaks and the ancient, mist-shrouded temples where time stands still. From the haunting gaze of a Sadhu to the raw power of a Bengal tiger, every shutter click captures a story of resilience and beauty. This is not just photography; it is a visual pilgrimage into the soul of the Himalayas."
        heroImage={heroBg.src}
        highlights={[
            {
                text: "Tshechu & Bisket Jatra Tour",
                link: "/photography/tshechu-festival-bisket-jatra",
            },
            {
                text: "Holi Festival Photography",
                link: "/photography/holi-festival",
            },
            {
                text: "Shaman Festival",
                link: "/photography/shaman-festival",
            },
            {
                text: "Mustang & Chitwan Expedition",
                link: "/photography/mustang-chitwan-expedition",
            },
        ]}
        galleryImages={[photo1.src, photo2.src, photo4.src]}
        client:visible
    />
</Layout>
