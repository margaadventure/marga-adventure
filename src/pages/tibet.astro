---
import Layout from "../layouts/Layout.astro";
import DestinationPage from "../components/DestinationPage";
import { getImage } from "astro:assets";
import tibetBg from "../assets/images/destinations/tibet/tibet-hero.webp";
import mountKailash from "../assets/images/destinations/tibet/mount-kailash.webp";
import tibetYak from "../assets/images/destinations/tibet/yak.webp";
import tibetCulture from "../assets/images/destinations/tibet/culture.webp";

const optimizedBg = await getImage({
    src: tibetBg,
    format: "webp",
    width: 2560,
});
const optimizedKailash = await getImage({
    src: mountKailash,
    format: "webp",
    width: 800,
});
const optimizedYak = await getImage({
    src: tibetYak,
    format: "webp",
    width: 800,
});
const optimizedCulture = await getImage({
    src: tibetCulture,
    format: "webp",
    width: 800,
});
---

<Layout
    title="Tibet"
    description="Journey to Tibet, where ancient spirituality meets the clouds. Marvel at the crimson majesty of Potala Palace in Lhasa, circle the sacred dust of Mount Kailash, and gaze upon the north face of Everest. With its turquoise lakes and high-altitude plateaus, Tibet offers a profound landscape steeped in mystery and deep Buddhist tradition."
    image={optimizedBg.src}
    keywords="Tibet travel, Tibet tours, Potala Palace, Mount Kailash, Everest Base Camp Tibet, Lhasa tours, spiritual travel Tibet, roof of the world"
>
    <DestinationPage
        country="Tibet"
        heroImage={optimizedBg.src}
        mainTitle="The Roof of the <span class='text-brand italic font-serif'>World</span>"
        description="Journey to Tibet, where ancient spirituality meets the clouds. Marvel at the majestic Potala Palace in Lhasa, circle the sacred Mount Kailash, and gaze upon the north face of Everest. With its turquoise lakes and high-altitude plateaus, Tibet offers a profound landscape steeped in mystery and deep Buddhist tradition."
        features={[
            {
                title: "Mount Kailash",
                text: "Circle the sacred Mount Kailash, a pilgrimage site for Buddhists and Hindus.",
                image: optimizedKailash.src,
            },
            {
                title: "Nomadic Spirit",
                text: "Encounter the resilient culture of the high-altitude nomads and their yak caravans.",
                image: optimizedYak.src,
            },
            {
                title: "Deep Devotion",
                text: "Immerse yourself in a land where every step is a pilgrimage and every breath is a prayer.",
                image: optimizedCulture.src,
            },
        ]}
        activeMonths={["MAY", "JUN", "JUL", "AUG", "SEP", "OCT"]}
        seasonNote="End of spring, summer and autumn offer the best blue light season for photography and travel in Tibet."
        client:visible
    />
</Layout>
