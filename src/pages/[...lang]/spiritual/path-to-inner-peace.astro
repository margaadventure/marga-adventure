---
export function getStaticPaths() {
  return [{ params: { lang: undefined } }, { params: { lang: 'fr' } }];
}

import { useAstroI18n } from "../../../i18n/astro";
import Layout from "../../../layouts/Layout.astro";
import TripItineraryPage from "../../../components/TripItineraryPage";

import bgImage from "../../../assets/images/activities/spiritual/The Path to inner peace .webp";
import type { Locale } from "../../../i18n/i18n";

const { lang, baseUrl, tripData, dict, enDict } = await useAstroI18n(Astro.url);
const trip = tripData("spiritual.innerPeaceTrip") || {};
---
<Layout
    title={`${trip.title || dict['spiritual.innerPeace']} | Marga Adventure`}
    image={bgImage.src}
    keywords={lang === 'en' ? "Path to Inner Peace, wellness journey Nepal, sound healing Nepal, ayurveda retreat Pokhara, spiritual wellness Nepal" : "Chemin vers la paix intérieure, voyage bien-être Népal, guérison par le son Népal, retraite ayurveda Pokhara, bien-être spirituel Népal"}
>
    <TripItineraryPage
        title={trip.title || dict['spiritual.innerPeace'] || "The Path to Inner Peace"}
        subtitle={trip.subtitle || "Wellness Journey"}
        heroImage={bgImage.src}
        overview={trip.overview || ""}
        highlights={trip.highlights || []}
        itinerary={trip.itinerary || []}
        tripStats={{
            duration: trip.duration || dict['trip.duration'] || "7 Days",
            maxAltitude: trip.maxAltitude || "Wellness / Yoga",
            maxAltitudeLabel: trip.maxAltitudeLabel || dict['trip.maxAltitude'] || "Trip Type",
            difficulty: trip.difficulty || dict['trip.easy'] || "Easy",
            groupSize: trip.groupSize || "2-10",
        }}
        showElevationGraph={false}
        client:visible
     initialLocale={lang}
     initialDict={dict}
     initialFallbackDict={enDict} />
</Layout>
