---
export function getStaticPaths() {
  return [{ params: { lang: undefined } }, { params: { lang: 'fr' } }];
}

import { useAstroI18n } from "../../../i18n/astro";
import Layout from "../../../layouts/Layout.astro";
import ExpeditionSpecialLayout from "../../../components/ExpeditionSpecialLayout";
import yogaImg1 from "../../../assets/images/activities/spiritual/Himalayan yoga trek .webp";
import yogaImg2 from "../../../assets/images/activities/spiritual/Himalayan yoga 2.webp";
import type { Locale } from "../../../i18n/i18n";

const { lang, baseUrl, tripData, dict, enDict } = await useAstroI18n(Astro.url);
const trip = tripData("spiritual.yogaTrip") || {};

const images = [yogaImg1.src, yogaImg2.src];
---
<Layout
    title={`${trip.title || dict['spiritual.yoga']} | Marga Adventure`}
    image={images[0]}
    keywords={lang === 'en' ? "Himalayan Yoga Trek, yoga trekking Nepal, altitude yoga, spiritual trekking Himalayas, meditation retreat Nepal mountains" : "Trek yoga Himalaya, yoga trekking Népal, yoga en altitude, trekking spirituel Himalaya, retraite méditation Népal"}
>
    <ExpeditionSpecialLayout
        title={trip.title || dict['spiritual.yoga'] || "Himalayan Yoga Trek"}
        overview={trip.overview || ""}
        images={images}
        highlights={trip.highlights || []}
        features={trip.features || []}
        tripStats={{
            destination: trip.destination || "Annapurna / Everest",
            difficulty: trip.difficulty || dict['trip.moderate'] || "Moderate",
            groupSize: trip.groupSize || "4-10",
            season: trip.season || "Spring / Autumn",
        }}
        client:visible
     initialLocale={lang}
     initialDict={dict}
     initialFallbackDict={enDict} />
</Layout>
