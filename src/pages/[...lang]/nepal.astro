---
export function getStaticPaths() {
  return [{ params: { lang: undefined } }, { params: { lang: 'fr' } }];
}

import { useAstroI18n } from "../../i18n/astro";
import Layout from "../../layouts/Layout.astro";
import { I18nNepalShell } from "../../components/I18nPageShells";
import type { Locale } from "../../i18n/i18n";
const { lang, baseUrl, t, dict, enDict } = await useAstroI18n(Astro.url);
---
<Layout
    title={t("nav.nepalMetaTitle")}
    description={t("nav.nepalMetaDesc")}
    image="/images/maps/nepal-map.webp"
    keywords={lang === 'en' ? "Nepal tours, trekking in Nepal, Nepal culture, Himalayas, Chitwan jungle safari, Kathmandu valley tour, Everest base camp" : "Circuits Népal, trekking au Népal, culture du Népal, Himalaya, safari jungle Chitwan, circuit vallée de Katmandou, camp de base de l'Everest"}
>
    <I18nNepalShell client:visible  initialLocale={lang} initialDict={dict} initialFallbackDict={enDict} />
</Layout>
