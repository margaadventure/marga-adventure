---
export function getStaticPaths() {
  return [{ params: { lang: undefined } }, { params: { lang: 'fr' } }];
}

import { useAstroI18n } from "../../i18n/astro";
import Layout from "../../layouts/Layout.astro";
import { I18nActivityShell } from "../../components/I18nActivityShells";
import spiritual1 from "../../assets/images/activities/spiritual/yoga-spiritual_1.webp";
import spiritual2 from "../../assets/images/activities/spiritual/meditation-spiritual_2.webp";
import spiritual3 from "../../assets/images/activities/spiritual/plant-spiritual_3.webp";
import bg from "../../assets/images/activities/spiritual/background.webp";
import type { Locale } from "../../i18n/i18n";
const { lang, baseUrl, t, tTrip, dict, enDict } = await useAstroI18n(Astro.url);
---
<Layout
    title={t("nav.spiritualMetaTitle")}
    description={t("nav.spiritualMetaDesc")}
    image={spiritual1.src}
    keywords={lang === 'en' ? "Spiritual retreat Nepal, meditation retreat Himalayas, Buddhist pilgrimage, yoga trek Nepal, mindfulness travel" : "Retraite spirituelle Népal, retraite méditation Himalaya, pèlerinage bouddhiste, trek yoga Népal, voyage pleine conscience"}
>
    <I18nActivityShell
        title={t("nepal.act2Title")}
        titleKey="nepal.act2Title"
        subtitle={t("nav.spiritualSubtitle")}
        description={t("nav.spiritualDescription")}
        heroImage={bg.src}
        highlights={[
            { text: tTrip("spiritual.pilgrimage"), link: `${baseUrl}/spiritual/buddhist-pilgrimage` },
            { text: tTrip("spiritual.innerPeace"), link: `${baseUrl}/spiritual/path-to-inner-peace` },
            { text: tTrip("spiritual.summit"), link: `${baseUrl}/spiritual/summit-within` },
            { text: tTrip("spiritual.yoga"), link: `${baseUrl}/spiritual/himalayan-yoga-trek` },
        ]}
        galleryImages={[spiritual1.src, spiritual2.src, spiritual3.src]}
        client:visible
      initialLocale={lang}
      initialDict={dict}
      initialFallbackDict={enDict} />
</Layout>
