---
export function getStaticPaths() {
  return [{ params: { lang: undefined } }, { params: { lang: 'fr' } }];
}

import { useAstroI18n } from "../../i18n/astro";
import Layout from "../../layouts/Layout.astro";
import trekking3 from "../../assets/images/404.webp";
import type { Locale } from "../../i18n/i18n";
const { lang, baseUrl, t } = await useAstroI18n(Astro.url);
---
<Layout title={t("notFound.label")} robots="noindex, nofollow">
    <div
        class="h-screen w-full flex items-center justify-center bg-gray-900 relative overflow-hidden"
    >
        <div class="absolute inset-0">
            <img
                src={trekking3.src}
                alt="Mist covered mountains"
                class="w-full h-full object-cover opacity-60"
            />
            <div
                class="absolute inset-0 bg-linear-to-t from-gray-900 via-transparent to-transparent"
            >
            </div>
        </div>

        <div class="relative z-10 text-center px-6 max-w-2xl mx-auto">
            <span
                class="inline-block py-1 px-3 border border-white/20 rounded-full text-brand font-bold tracking-[0.2em] uppercase text-xs mb-8 bg-black/30 backdrop-blur-sm"
                >{t("notFound.label")}</span
            >

            <h1
                class="text-6xl md:text-8xl font-bold text-white mb-6 tracking-tight"
                set:html={t("notFound.heading", { 
                    highlight: `<span class="text-brand italic font-serif">${t("notFound.headingHighlight")}</span>` 
                })}
            >
            </h1>

            <p
                class="text-gray-300 text-lg md:text-xl font-light leading-relaxed mb-12"
            >
                {t("notFound.body")}
            </p>

            <a
                href={`${baseUrl}`}
                class="inline-flex items-center gap-3 bg-brand text-white px-8 py-4 font-bold uppercase tracking-widest text-xs hover:bg-brand-dark transition-all transform hover:-translate-y-1 group"
            >
                <svg
                    class="w-4 h-4 transition-transform group-hover:-translate-x-1"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
                </svg>
                {t("notFound.returnHome")}
            </a>
        </div>
    </div>
</Layout>
