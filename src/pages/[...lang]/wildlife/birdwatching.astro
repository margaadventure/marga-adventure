---
export function getStaticPaths() {
  return [{ params: { lang: undefined } }, { params: { lang: 'fr' } }];
}

import { useAstroI18n } from "../../../i18n/astro";
import Layout from "../../../layouts/Layout.astro";
import { I18nActivityShell } from "../../../components/I18nActivityShells";
import birdWatchingBg from "../../../assets/images/activities/wildlife/birdwatching-hero.webp";
import bird3 from "../../../assets/images/activities/wildlife/bird-3.webp";
import peacock from "../../../assets/images/activities/wildlife/peacock.webp";
import bird2 from "../../../assets/images/activities/wildlife/bird-2.webp";
import type { Locale } from "../../../i18n/i18n";
const { lang, baseUrl, t, dict, enDict } = await useAstroI18n(Astro.url);
---
<Layout
    title={t("nav.wildlifeBirdingMetaTitle") || "Birdwatching"}
    description={t("nav.wildlifeBirdingMetaDesc") || "Spot the rare avian wonders of Nepal. With over 850 species, including the Spiny Babbler, our birdwatching tours are a paradise for naturalists."}
    image={bird3.src}
    keywords="Birdwatching Nepal, Himalayan birds, Koshi Tappu birding, Spiny Babbler, Nepal ornithology tour, bird photography Nepal"
>
    <I18nActivityShell
        title={t("wildlife.birdingTitle") || "Wings Over the Himalayas"}
        subtitle={t("wildlife.birdwatching") || "Birdwatching"}
        description={t("wildlife.birdingDesc") || "Embark on a birdwatching journey through Nepal, a hidden sanctuary boasting over 900 avian species."}
        heroImage={birdWatchingBg.src}
        highlights={[
            {
                text: t("wildlife.koshiExpedition") || "Kathmandu & Koshi Tappu Expedition",
                link: `${baseUrl}/wildlife/kathmandu-koshi-birding`,
            },
        ]}
        galleryImages={[bird3.src, peacock.src, bird2.src]}
        client:load
        initialLocale={lang}
        initialDict={dict}
        initialFallbackDict={enDict}
    />
</Layout>
