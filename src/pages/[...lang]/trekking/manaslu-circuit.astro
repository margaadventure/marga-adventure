---
export function getStaticPaths() {
  return [{ params: { lang: undefined } }, { params: { lang: 'fr' } }];
}

import { useAstroI18n } from "../../../i18n/astro";
import Layout from "../../../layouts/Layout.astro";
import TripItineraryPage from "../../../components/TripItineraryPage";
import manasluImg from "../../../assets/images/activities/trekking/manaslu_trekking.webp";
import type { Locale } from "../../../i18n/i18n";

const { lang, baseUrl, t, tripData: tripDataFn, dict } = await useAstroI18n(Astro.url);
const tripData = tripDataFn("trekking.manaslu-circuit") as any;

// Fallback data in case translation is missing (optional, as tripData should be complete)
const fallbackItinerary = [
    {
        day: "Day 1",
        title: "Arrival in Kathmandu and transfer to hotel",
        description: "Upon your arrival at Tribhuvan International Airport in Kathmandu, you will be greeted and transferred to your hotel in the city. The rest of the day is free for you to rest after your journey, stroll through the vibrant streets of Thamel, or simply relax. In the evening, there will be a trek briefing where you will meet your guide and discuss the Manaslu Circuit adventure ahead while permits and logistics are finalized.",
        stats: {},
    },
    // ... other days if needed for very robust fallback ...
];
---
<Layout
    title={tripData.title}
    image={manasluImg.src}
    keywords="Manaslu Circuit Trek, Larke La Pass, restricted area trekking Nepal, Manaslu base camp, off the beaten path Nepal"
>
    <TripItineraryPage
        title={tripData.title}
        subtitle={tripData.subtitle}
        heroImage={manasluImg.src}
        overview={tripData.overview}
        highlights={tripData.highlights}
        itinerary={tripData.itinerary}
        tripStats={{
            duration: tripData.duration || "15 Days",
            maxAltitude: tripData.maxAltitude || "5,160m",
            difficulty: tripData.difficulty || t("trip.hard"),
            groupSize: tripData.groupSize || "2-12",
        }}
        client:load
     initialLocale={lang}
     initialDict={dict} />
</Layout>
