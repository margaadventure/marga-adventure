---
import Layout from "../layouts/Layout.astro";
---

<Layout title="404 - Are You Lost? | Marga Adventure">
    <div
        class="relative h-screen flex items-center justify-center overflow-hidden bg-black"
    >
        {/* Background - Using a misty/mysterious mountain image */}
        <div class="absolute inset-0">
            <img
                src="/images/Trekking/DSCN7142.webp"
                alt="Lost in the Himalayas"
                class="w-full h-full object-cover opacity-40"
            />
            <div
                class="absolute inset-0 bg-gradient-to-b from-black/80 via-black/40 to-black/80"
            >
            </div>
        </div>

        <div class="relative z-10 text-center px-6 max-w-2xl mx-auto">
            <span
                class="inline-block py-1 px-3 border border-white/20 rounded-full text-brand font-bold tracking-[0.2em] uppercase text-xs mb-8 bg-black/30 backdrop-blur-sm"
                >404 Error</span
            >

            <h1
                class="text-6xl md:text-8xl font-bold text-white mb-6 tracking-tight"
            >
                Are You <span class="text-brand italic font-serif">Lost?</span>
            </h1>

            <p
                class="text-gray-300 text-lg md:text-xl font-light leading-relaxed mb-12"
            >
                Even in the wildest mountains, every path leads somewhere. It
                seems you've wandered off the trail, but finding your way back
                is part of the journey.
            </p>

            <a
                href="/"
                class="inline-flex items-center gap-3 bg-brand text-white px-8 py-4 font-bold uppercase tracking-widest text-xs hover:bg-brand-dark transition-all transform hover:-translate-y-1 group"
            >
                <svg
                    class="w-4 h-4 transition-transform group-hover:-translate-x-1"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
                </svg>
                Return Home
            </a>
        </div>
    </div>
</Layout>
