---
import Layout from "../layouts/Layout.astro";
import ActivityPage from "../components/ActivityPage";
import spiritual1 from "../assets/images/activities/spiritual/yoga-spiritual_1.jpeg";
import spiritual2 from "../assets/images/activities/spiritual/meditation-spiritual_2.png";
import spiritual3 from "../assets/images/activities/spiritual/plant-spiritual_3.jpg";
import bg from "../assets/images/activities/spiritual/background.jpg";
---

<Layout
    title="Spiritual Retreat"
    description="Awaken your spirit in the birthplace of peace. From Lumbini to high-altitude monasteries, our spiritual retreats offer a path to inner silence."
    image={spiritual1.src}
>
    <ActivityPage
        title="Awaken in the Himalayas"
        subtitle="Spiritual Retreat"
        description="Nepal is a sanctuary where the spirit finds its home. From the sacred birth of peace in Lumbini to the meditative silence of high-altitude monasteries, every breath here feels like a prayer. Immerse yourself in the rhythm of chanting monks and the stillness of the mountains. This is not just a retreat; it is a soulful journey to rediscover your inner light amidst the clouds."
        heroImage={bg.src}
        highlights={[
            {
                text: "A Buddhist Pilgrimage",
                link: "/spiritual/buddhist-pilgrimage",
            },
            {
                text: "The Path to Inner Peace",
                link: "/spiritual/path-to-inner-peace",
            },
            {
                text: "Himalayan Yoga Trek",
                link: "/spiritual/himalayan-yoga-trek",
            },
            {
                text: "The Summit Within (Spiritual Ascent)",
                link: "/spiritual/summit-within",
            },
        ]}
        galleryImages={[spiritual1.src, spiritual2.src, spiritual3.src]}
        client:visible
    />
</Layout>
