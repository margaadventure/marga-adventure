---
import Layout from "../layouts/Layout.astro";
import ActivityPage from "../components/ActivityPage";
import spiritual1 from "../assets/images/activities/spiritual/yoga-spiritual_1.webp";
import spiritual2 from "../assets/images/activities/spiritual/meditation-spiritual_2.webp";
import spiritual3 from "../assets/images/activities/spiritual/plant-spiritual_3.webp";
import bg from "../assets/images/activities/spiritual/background.webp";
---

<Layout
    title="Spiritual Retreat"
    description="Awaken your spirit in the birthplace of peace. From Lumbini to high-altitude monasteries, our spiritual retreats offer a path to inner silence."
    image={spiritual1.src}
    keywords="Spiritual retreat Nepal, meditation retreat Himalayas, Buddhist pilgrimage, yoga trek Nepal, mindfulness travel"
>
    <ActivityPage
        title="Awaken in the Himalayas"
        subtitle="Spiritual Retreat"
        description="Nepal is the sanctuary where the spirit finds its rest. From the sacred birth-hush of Lumbini to the meditative silence of high-altitude monasteries, every breath is a conscious act of peace. Immerse yourself in the rhythmic chanting of monks and the profound stillness of the peaks.This is not just a retreat; it is a soulful journey to rediscover your inner light amidst the clouds."
        heroImage={bg.src}
        highlights={[
            {
                text: "A Buddhist Pilgrimage",
                link: "/spiritual/buddhist-pilgrimage",
            },
            {
                text: "The Path to Inner Peace",
                link: "/spiritual/path-to-inner-peace",
            },

            {
                text: "The Summit Within (Spiritual Ascent)",
                link: "/spiritual/summit-within",
            },
            {
                text: "Himalayan Yoga Trek",
                link: "/spiritual/himalayan-yoga-trek",
            },
        ]}
        galleryImages={[spiritual1.src, spiritual2.src, spiritual3.src]}
        client:visible
    />
</Layout>
