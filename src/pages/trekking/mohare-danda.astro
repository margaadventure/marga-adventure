const itinerary = [
    {
        day: "Day 1",
        title: "Arrival and Transfer to Hotel",
        description:
            "Upon your arrival at Tribhuvan International Airport, you will be greeted and transferred to your hotel in the vibrant Thamel district. The rest of the day is yours to recover from your journey and soak in the bustling atmosphere of the capital. You can enjoy a traditional Nepali welcome dinner or take a leisurely evening stroll through the colorful markets to pick up any last-minute trekking gear.",
        stats: {},
    },
    {
        day: "Day 2",
        title: "Explore Kathmandu Valley",
        description:
            "Today is dedicated to exploring the spiritual heart of Nepal. You will visit the ancient city of Patan, famous for its intricate wood and stone carvings. Later, you'll experience the peaceful atmosphere of Boudhanath Stupa, one of the largest Buddhist monuments in the world. Finally, you will witness the sacred Hindu rituals at Pashupatinath Temple on the banks of the Bagmati River, offering a deep dive into Nepal's heritage.",
        stats: {},
    },
    {
        day: "Day 3",
