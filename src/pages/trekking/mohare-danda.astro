        title="Mohare Danda Trek"
        subtitle="Eco-Community Trek"
        heroImage={mohareImg.src}
        overview={overview}
        highlights={highlights}
        itinerary={itinerary}
        tripStats={{
            duration: "10 Days",
            maxAltitude: "3,313m",
            difficulty: "Moderate",
            groupSize: "2-12",
        }}
        client:visible
    />
</Layout>
