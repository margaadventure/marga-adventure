const overview = `The Manaslu Circuit Trek is one of Nepal’s most spectacular and culturally rich trekking routes, taking you around Mount Manaslu (8,163m), the eighth-highest mountain in the world. Often nicknamed the "Spirit Mountain" by locals, this region offers a quieter and less-commercialized alternative to the more crowded Annapurna and Everest treks. The trail showcases a dramatic evolution of landscapes, transitioning from the steamy, subtropical terraced fields of the Budhi Gandaki valley to the stark, windswept alpine terrain near the Tibetan border.

Culturally, the region is incredibly authentic; trekkers pass through villages like Samagaun and Samdo, where ancient Tibetan Buddhist traditions and monasteries remain virtually untouched by modernity. The journey’s crowning challenge is the crossing of the Larkya La Pass (5,106m), a physical feat that rewards you with panoramic views of Himlung Himal, Cheo Himal, and Annapurna II. Designated as a Restricted Area requiring special permits, the Manaslu Circuit retains a sense of exclusivity and raw wilderness perfect for solitude seekers.`;
---

<Layout
    title="Manaslu Circuit Trek"
    description="A pristine journey around the world's 8th highest peak, offering secluded trails, rich Tibetan culture, and the challenging Larke La Pass."
>
    <TripItineraryPage
        title="Manaslu Circuit Trek"
        subtitle="Spirit of the Mountains"
        heroImage={manasluImg.src}
        overview={overview}
        highlights={highlights}
        itinerary={itinerary}
        tripStats={{
            duration: "15 Days",
            maxAltitude: "5,160m",
            difficulty: "Hard",
            groupSize: "2-12",
        }}
        client:visible
    />
</Layout>
