---
import Header from "./Header";
import type { MenuImages } from "./MenuOverlay";
import { getImage } from "astro:assets";

// Import images
import img1 from "../assets/images/ui/menu/Flower.webp";
import img2 from "../assets/images/ui/menu/rhino-menu_2.webp";
import img3 from "../assets/images/ui/menu/tsechu-menu_3.webp";
import img4 from "../assets/images/ui/menu/village-menu_4.webp";
import img5 from "../assets/images/ui/menu/bisket-menu_7.webp";
import img6 from "../assets/images/ui/menu/lomanthang-menu_8.webp";
import img7 from "../assets/images/ui/menu/navadurgajatra-menu_6.webp";

import nepalImg from "../assets/images/country/nepal.webp";
import bhutanImg from "../assets/images/country/bhutan.webp";
import tibetImg from "../assets/images/country/Tibet.webp";

const optimizeData = {
    scroll: [img1, img2, img3, img4, img5, img6, img7],
    destinations: {
        nepal: nepalImg,
        bhutan: bhutanImg,
        tibet: tibetImg,
    },
};

// Helper to optimize
// Using slightly larger width for retina displays, but compressed webp
const scrollImages = await Promise.all(
    optimizeData.scroll.map(async (img) => {
        const optimized = await getImage({
            src: img,
            format: "webp",
            width: 800,
            quality: 60,
        });
        return optimized.src;
    }),
);

const nepalSrc = (
    await getImage({ src: nepalImg, format: "webp", width: 800, quality: 60 })
).src;
const bhutanSrc = (
    await getImage({ src: bhutanImg, format: "webp", width: 800, quality: 60 })
).src;
const tibetSrc = (
    await getImage({ src: tibetImg, format: "webp", width: 800, quality: 60 })
).src;

const menuImages: MenuImages = {
    scrollImages,
    destinations: {
        nepal: nepalSrc,
        bhutan: bhutanSrc,
        tibet: tibetSrc,
    },
};

interface Props {
    forceOpaque?: boolean;
    initialLocale?: string;
}

import { useAstroI18n } from "../i18n/astro";

const { forceOpaque, initialLocale } = Astro.props;
const { dict, enDict } = await useAstroI18n(Astro.url);
---

<Header client:load initialLocale={initialLocale as any} initialDict={dict} initialFallbackDict={enDict} forceOpaque={forceOpaque} menuImages={menuImages} />
