---
import Footer from "./Footer";
import { getImage } from "astro:assets";

// Import logos to be optimized
import ntbLogo from "../assets/images/logos/Nepal-Tourism-Board_Logo-full.webp";
import taanLogo from "../assets/images/logos/taan-logo.webp";
import nmaLogo from "../assets/images/logos/NMA-Logo-removebg-preview.webp";

const footerData = {
    ntb: ntbLogo,
    taan: taanLogo,
    nma: nmaLogo,
};

// Optimize logos
const ntbSrc = (
    await getImage({ src: ntbLogo, format: "webp", width: 200, quality: 75 })
).src;
const taanSrc = (
    await getImage({ src: taanLogo, format: "webp", width: 200, quality: 75 })
).src;
const nmaSrc = (
    await getImage({ src: nmaLogo, format: "webp", width: 200, quality: 75 })
).src;

const footerImages = {
    ntb: ntbSrc,
    taan: taanSrc,
    nma: nmaSrc,
};
---

<Footer client:visible footerImages={footerImages} />
