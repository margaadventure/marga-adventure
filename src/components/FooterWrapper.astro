---
import { getImage } from "astro:assets";
import I18nFooterShell from "./I18nFooterShell";

// Import logos to be optimized
import ntbLogo from "../assets/images/logos/Nepal-Tourism-Board_Logo-full.webp";
import taanLogo from "../assets/images/logos/taan-logo.webp";
import nmaLogo from "../assets/images/logos/NMA-Logo-removebg-preview.webp";

// Optimize logos
const ntbSrc = (
    await getImage({ src: ntbLogo, format: "webp", width: 200, quality: 75 })
).src;
const taanSrc = (
    await getImage({ src: taanLogo, format: "webp", width: 200, quality: 75 })
).src;
const nmaSrc = (
    await getImage({ src: nmaLogo, format: "webp", width: 200, quality: 75 })
).src;

const footerImages = {
    ntb: ntbSrc,
    taan: taanSrc,
    nma: nmaSrc,
};

import { useAstroI18n } from "../i18n/astro";

const { initialLocale } = Astro.props;
const { dict, enDict } = await useAstroI18n(Astro.url);
---

<I18nFooterShell client:load initialLocale={initialLocale as any} initialDict={dict} initialFallbackDict={enDict} footerImages={footerImages} />
